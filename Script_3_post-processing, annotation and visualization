# Helper: build z-scored expression matrix for given genes from raw counts
get_top_gene_matrix <- function(tt, counts_mat) {
  gene_ids <- rownames(tt)
  mat <- counts_mat[gene_ids, , drop = FALSE]
  t(scale(t(mat)))
}

