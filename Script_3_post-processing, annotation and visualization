# Helper: merge per-contrast tables for a given set of genes
merge_common_degs <- function(genes, hff, mrc5, imr, bj, wi38,
                              suffix_hff = ".HFF",
                              suffix_mrc5 = ".MRC5",
                              suffix_imr = ".IMR",
                              suffix_bj = ".BJ",
                              suffix_wi38 = ".WI38") {

  # Filter on selected genes (up/down only)
  hff_f   <- hff[hff$GeneID   %in% genes, ]
  mrc5_f  <- mrc5[mrc5$GeneID %in% genes, ]
  imr_f   <- imr[imr$GeneID   %in% genes, ]
  bj_f    <- bj[bj$GeneID     %in% genes, ]
  wi38_f  <- wi38[wi38$GeneID %in% genes, ]

  # Add suffix to column names, keep GeneID
  hff_f   <- hff_f  %>% rename_with(~ paste0(., suffix_hff),   -GeneID)
  mrc5_f  <- mrc5_f %>% rename_with(~ paste0(., suffix_mrc5),  -GeneID)
  imr_f   <- imr_f  %>% rename_with(~ paste0(., suffix_imr),   -GeneID)
  bj_f    <- bj_f   %>% rename_with(~ paste0(., suffix_bj),    -GeneID)
  wi38_f  <- wi38_f %>% rename_with(~ paste0(., suffix_wi38),  -GeneID)

  merged <- hff_f %>%
    full_join(mrc5_f, by = "GeneID") %>%
    full_join(imr_f,  by = "GeneID") %>%
    full_join(bj_f,   by = "GeneID") %>%
    full_join(wi38_f, by = "GeneID")

  merged
}

