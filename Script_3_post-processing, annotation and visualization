make_volcano <- function(deg_table, label, ylim_max = 20,
                         adjp_thresh = adjp_value_threshold,
                         logfc_thresh = logFC_threshold) {

  up_genes   <- deg_table %>% filter(flag == "up")
  down_genes <- deg_table %>% filter(flag == "down")

  n_up   <- nrow(up_genes)
  n_down <- nrow(down_genes)
  n_tot  <- n_up + n_down

  plot_title <- paste(
    label,
    "- Up:", n_up,
    "- Down:", n_down,
    "- Total significant:", n_tot
  )

  EnhancedVolcano(
    deg_table,
    lab          = deg_table$gene_name,
    x            = "logFC",
    y            = "adj.P.Val",
    ylim         = c(0, ylim_max),
    title        = plot_title,
    pCutoff      = adjp_thresh,
    FCcutoff     = logfc_thresh,
    ylab         = expression(-Log[10] ~ adj ~ p.value),
    legendLabels = c(
      "NS",
      expression(Log[2] ~ FC),
      "adjp-value",
      expression(adjp - value ~ and ~ Log[2] ~ FC)
    )
  )
}

