# Helper function: get annotated DEG table for one contrast
get_deg_table <- function(fit, coef_name, annot, label,
                          adjp_thresh = 0.05, logfc_thresh = 0.58,
                          out_dir = output_dir) {
  tt <- topTable(
    fit,
    coef           = coef_name,
    number         = Inf,
    adjust.method  = "BH"
  )

  # Order by logFC (descending)
  tt <- tt[order(tt$logFC, decreasing = TRUE), ]

  # Merge with gene annotation
  tt_annot <- merge(
    tt,
    annot,
    by.x    = "GeneID",
    by.y    = "gene_id",
    all.y   = TRUE,
    sort    = FALSE,
    suffixes = c("_deg", "_annot")
  )

  # Remove NA logFC rows
  tt_annot <- tt_annot[!is.na(tt_annot$logFC), ]

  # Flag: up, down, NS
  tt_annot$flag <- ifelse(
    tt_annot$adj.P.Val < adjp_thresh & tt_annot$logFC >  logfc_thresh, "up",
    ifelse(
      tt_annot$adj.P.Val < adjp_thresh & tt_annot$logFC < -logfc_thresh, "down",
      "NS"
    )
  )

  print(table(tt_annot$flag))
  if ("gene_biotype" %in% colnames(tt_annot)) {
    print(table(tt_annot$gene_biotype))
  }

  # Export to Excel
  out_file <- file.path(
    out_dir,
    paste0(label, "_adjp", adjp_thresh, "_logFC", logfc_thresh, ".xlsx")
  )
  write.xlsx(tt_annot, out_file)

  tt_annot
}

