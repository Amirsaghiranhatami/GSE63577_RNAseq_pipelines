############################################################
# GSE63577 RNA‑seq raw counts preprocessing
# - Download count matrix from GEO
# - Filter lowly expressed genes
# - Basic QC plots
# - Build sample and gene annotation tables
############################################################

## Load required packages ----------------------------------

library(data.table)
library(edgeR)
library(grDevices)
library(BiocGenerics)
