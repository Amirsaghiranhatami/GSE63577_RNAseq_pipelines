############################################################
# 1. Download and import count data
############################################################

# GEO series ID: GSE63577
base_url <- "https://www.ncbi.nlm.nih.gov/geo/download/?format=file&type=rnaseq_counts"

# Build full download URL
counts_url <- paste(
  base_url,
  "acc=GSE63577",
  "file=GSE63577_raw_counts_GRCh38.p13_NCBI.tsv.gz",
  sep = "&"
)

# Read counts table
# Assumes a column 'GeneID' with gene identifiers
counts_dt <- data.table::fread(counts_url, header = TRUE)

GSE63577 <- as.data.frame(counts_dt)
rownames(GSE63577) <- GSE63577$GeneID
GSE63577$GeneID <- NULL

# Remove specific samples:
# - middle stage for MRC5 (passage 52, 62)
# - middle stage for HFF  (passage 26, 46, 64)
# NOTE: indices assume original column ordering
GSE63577 <- GSE63577[, -46]
GSE63577 <- GSE63577[, -c(28:36, 40:45)]

############################################################
# 2. Filter and normalize count data
############################################################

#' Filter and QC RNA‑seq count matrix
#'
#' @param X genes-by-samples count matrix
#' @param out_dir output directory for QC plots
#' @param col vector of point colors (length = ncol(X)); if NULL, a default is used
#' @param min.cpm minimum counts per million in at least min.samples samples
#' @param min.counts minimum raw count if filter.by.cpm = FALSE
#' @param min.samples minimum number of samples a gene must be expressed in
#' @param prior.count prior.count for cpm() when log = TRUE
#' @param filter.by.cpm if TRUE, filter by CPM; otherwise filter by raw counts
#' @param width, height, res, units graphical parameters for plots
#'
#' @return filtered count matrix
#'
filter_counts <- function(
  X,
  out_dir       = "filtering_result",
  col           = NULL,
  width         = 180,
  height        = 180,
  res           = 300,
  units         = "mm",
  prior.count   = 3,
  filter.by.cpm = TRUE,
  min.cpm       = 3,
  min.counts    = 10,
  subset.remove = NULL,
  min.samples   = NULL
) {
  dir.create(out_dir, recursive = TRUE, showWarnings = FALSE)

  # Replace NAs with zero
  X[is.na(X)] <- 0

  # Optionally remove specific samples
  if (!is.null(subset.remove)) {
    message("Removing ", sum(colnames(X) %in% subset.remove), " samples.")
    X <- X[, !colnames(X) %in% subset.remove, drop = FALSE]
  }

  # Default colors: one per sample
  if (is.null(col)) {
    col <- seq_len(ncol(X))
  }

  ## FILTERING
  message("FILTERING...")

  # Remove all-zero genes
  zero_rows <- rowSums(X) == 0
  if (any(zero_rows)) {
    message("Removing ", sum(zero_rows), " all-zero genes.")
    X <- X[!zero_rows, , drop = FALSE]
  }

  # Default: gene must be expressed in at least 25% of samples
  if (is.null(min.samples)) {
    min.samples <- round(ncol(X) * 0.25)
  }

  # Create DGEList object
  dge <- DGEList(X)

  if (filter.by.cpm) {
    # Filter by CPM
    cpm_values <- cpm(dge)
    message(
      "Keeping genes with at least ", min.cpm,
      " CPM in ", min.samples, " samples..."
    )
    keep <- rowSums(cpm_values >= min.cpm) >= min.samples
  } else {
    # Filter by raw counts
    message(
      "Keeping genes with at least ", min.counts,
      " counts in ", min.samples, " samples..."
    )
    keep <- rowSums(X >= min.counts) >= min.samples
  }

  print(table(keep))

  X_filt <- X[keep, , drop = FALSE]
  message("Filtered counts dimensions: ", paste(dim(X_filt), collapse = " x "))

  ## log-CPM for QC plots
  dge_all  <- DGEList(X)
  lcpm_all <- cpm(dge_all, log = TRUE, prior.count = prior.count)

  dge_filt  <- DGEList(X_filt)
  lcpm_filt <- cpm(dge_filt, log = TRUE, prior.count = prior.count)

  ## Density plots: raw vs filtered
  jpeg(
    filename = file.path(out_dir, "density.jpg"),
    width    = width,
    height   = height / 2,
    res      = res,
    units    = units
  )

  par(mfrow = c(1, 2))

  dens_all <- apply(lcpm_all, 2, density)
  xlim_all <- summary(unlist(lapply(dens_all, function(x) x$x)))[c(1, 6)]
  ylim_all <- summary(unlist(lapply(dens_all, function(x) x$y)))[c(1, 6)]

  plot(
    dens_all[[1]]$x, dens_all[[1]]$y,
    xlim = xlim_all, ylim = ylim_all,
    xlab = "log-CPM", ylab = "Density",
    main = "Raw", type = "l"
  )
  for (i in 2:length(dens_all)) {
    lines(dens_all[[i]]$x, dens_all[[i]]$y, col = i)
  }
  abline(v = 0, lty = 2)

  dens_filt <- apply(lcpm_filt, 2, density)
  xlim_filt <- summary(unlist(lapply(dens_filt, function(x) x$x)))[c(1, 6)]
  ylim_filt <- summary(unlist(lapply(dens_filt, function(x) x$y)))[c(1, 6)]

  plot(
    dens_filt[[1]]$x, dens_filt[[1]]$y,
    xlim = xlim_filt, ylim = ylim_filt,
    xlab = "log-CPM", ylab = "Density",
    main = "Filtered", type = "l"
  )
  for (i in 2:length(dens_filt)) {
    lines(dens_filt[[i]]$x, dens_filt[[i]]$y, col = i)
  }
  abline(v = 0, lty = 2)

  dev.off()

  ## Number of samples per gene and genes per sample
  n_samples_per_gene <- rowSums(sign(X_filt))
  n_genes_per_sample <- colSums(sign(X_filt))

  png(
    filename = file.path(out_dir, "library.size.genes.png"),
    width    = width,
    height   = height / 2,
    units    = "mm",
    res      = 300
  )

  par(mfrow = c(1, 2))
  par(mgp = c(2, 0.5, 0))

  hist(
    n_samples_per_gene,
    breaks = 20,
    xlab   = "Number of samples",
    ylab   = "Number of genes",
    main   = "Gene occurrence in samples",
    cex.lab = 0.6,
    cex     = 0.6,
    cex.axis = 0.6,
    las      = 2,
    cex.main = 0.6
  )

  hist(
    n_genes_per_sample,
    breaks = 20,
    xlab   = "Number of genes",
    ylab   = "Number of samples",
    main   = "Number of expressed genes",
    cex.lab = 0.6,
    cex     = 0.6,
    cex.axis = 0.6,
    las      = 2,
    cex.main = 0.6
  )

  dev.off()

  ## Library size vs number of expressed genes (log-log)
  png(
    filename = file.path(out_dir, "library_sizes.ngenes.counts.png"),
    width    = width,
    height   = height,
    units    = "mm",
    res      = 300
  )

  par(mgp = c(1.5, 0.5, 0))

  plot(
    colSums(X_filt),
    n_genes_per_sample,
    cex      = 0.6,
    col      = col,
    xlab     = "# reads",
    ylab     = "# genes",
    pch      = 16,
    log      = "xy",
    cex.axis = 0.6,
    cex.lab  = 0.6
  )

  dev.off()

  return(X_filt)
}

############################################################
# 3. Apply filtering to GSE63577
############################################################

GSE63577_filtered <- filter_counts(
  X            = GSE63577,
  out_dir      = "filtering_result",
